{
  "name": "@startupbros/pi-operator-mode",
  "version": "0.1.0",
  "description": "Operator-mode recovery for execution-like Pi prompts.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "operator-mode",
    "execution",
    "retry"
  ],
  "type": "module",
  "files": [
    "extensions/",
    "src/",
    "test/",
    "README.md",
    "tsconfig.json"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "check": "pnpm typecheck && pnpm test"
  },
  "packageManager": "pnpm@10.26.2",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StartupBros/pi-operator-mode.git"
  },
  "bugs": {
    "url": "https://github.com/StartupBros/pi-operator-mode/issues"
  },
  "homepage": "https://github.com/StartupBros/pi-operator-mode#readme",
  "author": "StartupBros",
  "license": "MIT"
}
